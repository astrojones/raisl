{
  "extraKnownMarketplaces": {
    "astrojones": {
      "source": {
        "source": "github",
        "repo": "astrojones/claude-plugins"
      }
    }
  },
  "enabledPlugins": {
    "raisl@astrojones": true
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
